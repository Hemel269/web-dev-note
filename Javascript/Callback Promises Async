## let undrestand callback hell :

function getData(dataId, getNextdata) {
  setTimeout(() => {                                         // Wait 2 seconds before running the function
    console.log(dataId);                                 // Print the current dataId 
    if (getNextdata) {                                    // If there is a "next function" provided, call it
      getNextdata();                                     // Go to the next step
    }
  }, 2000);
}

// Start the chain
getData(1, () => {       // Step 1: print 1 after 2 sec
  getData(2, () => {     // Step 2: print 2 after 2 sec
    getData(3, () => {   // Step 3: print 3 after 2 sec
      getData(4);        // Step 4: print 4 after 2 sec (no next function)
    });
  });
});

so it will print 1 wait 2 sec print 2 wait 2 sec like this..
its look so messy so its called callback hell..

another example but useing string:

function sayHello(name, next) {
  setTimeout(() => {
    console.log(name);
    if (next) {
      next();
    }
  }, 1000);
}
//callback hell
sayHello("alice", () => {
  sayHello("bob", () => {
    sayHello("chirlie");
  });
});

